  <!-- ===================================================================
       5-BAR LINKAGE CLOSURE  (FK reference at q=0, all revolute joints zero)
         Left arm origin in base_link    : (0.071,  0.4953, -0.3918)
         Right arm origin in base_link   : (0.075, -0.4953, -0.3918)
         Tip length L = 0.4953/0.7956   = 0.6225 m
         Closure point in base_link      : (~0.073, 0, -0.769)   <- X_EE_PLANE = 0.073
       The two distal links (Chain1_link_2, Chain2_link_2) meet at this closure point.
       HOW THE LOOP IS CLOSED depends on the render (see flag-gated includes below):
         - Gazebo  (sim):         DetachableJoint weld + helper frames (fivebar_linkage.gazebo.xacro)
         - robot_model (constraints): two spherical <constraint>s to tool0 (fivebar_linkage.constraints.xacro)
         - MoveIt  (planning):    phantom tool chain only          (fivebar_linkage.moveit.xacro)
       The base tree above is shared by all renders and stays parser-agnostic.
       =================================================================== -->

  <!-- ===================================================================
       Single source of truth: one kinematic tree, four orthogonal add-on renders,
       each gated by its own arg and split into its own macro file (mirrors the
       existing sim/gazebo split). Each launch context renders with the flags it needs:
         Gazebo:      sim:=true ros2_control:=true
         MoveIt:      planning:=true
         transformer: planning:=true constraints:=true   (constraints need tool0 from the phantom chain)
       =================================================================== -->
  <xacro:arg name="sim"          default="true"/>
  <xacro:arg name="ros2_control" default="false"/>
  <xacro:arg name="planning"     default="false"/>
  <xacro:arg name="constraints"  default="false"/>

  <!-- Gazebo system plugins + DetachableJoint loop closure (+ closure helper frames) -->
  <xacro:if value="$(arg sim)">
    <xacro:include filename="fivebar_linkage.gazebo.xacro"/>
  </xacro:if>

  <!-- ros2_control hardware interface on the active joints (gz_ros2_control in sim) -->
  <xacro:if value="$(arg ros2_control)">
    <xacro:include filename="fivebar_linkage.ros2_control.xacro"/>
  </xacro:if>

  <!-- MoveIt phantom planning chain to tool0 -->
  <xacro:if value="$(arg planning)">
    <xacro:include filename="fivebar_linkage.moveit.xacro"/>
  </xacro:if>

  <!-- Closed-loop <constraint> elements + transmissions for robot_model -->
  <xacro:if value="$(arg constraints)">
    <xacro:include filename="fivebar_linkage.constraints.xacro"/>
  </xacro:if>
</robot>