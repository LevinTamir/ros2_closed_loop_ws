<?xml version="1.0" ?>
<!-- 3-DoF delta (ported from PARA_ENGINEER.urdf) into the volcaniarm closed-loop pattern. -->
<!-- Assembled home: theta=0, platform drop Z_P=0.14050 m, forearm home bend BETA=2.14001 rad. -->
<robot name="deltaarm_3dof">

  <link name="world"/>
  <joint name="world_to_base" type="fixed">
    <origin xyz="0 0 1.000000" rpy="0 0 0"/>
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 -0.53"/>
      <geometry>
        <mesh filename="package://closed_loop_description/meshes/PARA_ENGINEER/Kopfplatte.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="mat_base">
        <color rgba="0.25 0.25 0.25 1.0"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.015" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.02"/>
    </inertial>
  </link>

  <!-- ===================== leg 1 (phi = 0 deg) ===================== -->
  <link name="Chain1_link_1">
    <visual>
      <origin xyz="0 0 0" rpy="1.570 0 1.570"/>
      <geometry>
        <mesh filename="package://closed_loop_description/meshes/PARA_ENGINEER/Oberarm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="mat_arm">
        <color rgba="0.25 0.25 0.25 1.0"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0.0379 0 0" rpy="0 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="5e-05" ixy="0" ixz="0" iyy="0.0006" iyz="0" izz="0.0006"/>
    </inertial>
  </link>
  <joint name="Chain1_1" type="revolute">
    <parent link="base_link"/>
    <child link="Chain1_link_1"/>
    <origin xyz="0.041700 0.000000 0" rpy="0 0 0.000000"/>
    <axis xyz="0 1 0"/>
    <limit effort="230.0" lower="-1.0297442586766543" upper="1.4311699866353502" velocity="785.3981633974483"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>
  <link name="Chain1_forearm">
    <visual>
      <origin xyz="0 0 0" rpy="0 3.141 0"/>
      <geometry>
        <mesh filename="package://closed_loop_description/meshes/PARA_ENGINEER/Unterarm.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="mat_arm">
        <color rgba="0.25 0.25 0.25 1.0"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0.0834 0 0" rpy="0 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="0.0007" iyz="0" izz="0.0007"/>
    </inertial>
  </link>
  <link name="Chain1_top_v1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
    </inertial>
  </link>
  <link name="Chain1_top_v2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
