    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="99999.0" lower="-3.141592653589793" upper="3.141592653589793" velocity="99999.0"/>
    <dynamics damping="0.02" friction="0.0"/>
  </joint>
  <joint name="Chain3_cl_C" type="revolute">
    <parent link="Chain3_cl_v2"/>
    <child link="Chain3_dummy"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="99999.0" lower="-3.141592653589793" upper="3.141592653589793" velocity="99999.0"/>
    <dynamics damping="0.02" friction="0.0"/>
  </joint>
  <gazebo>
    <plugin filename="libgz-sim-detachable-joint-system.so"
            name="gz::sim::systems::DetachableJoint">
      <parent_link>Chain3_tip</parent_link>
      <child_model>deltaarm_3dof</child_model>
      <child_link>Chain3_dummy</child_link>
    </plugin>
  </gazebo>

  <!-- actuated joint controllers -->
  <gazebo>
    <plugin filename="libgz-sim-joint-position-controller-system.so"
            name="gz::sim::systems::JointPositionController">
      <joint_name>Chain1_1</joint_name>
      <topic>/delta_3dof/Chain1_1/cmd_pos</topic>
      <p_gain>20</p_gain>
      <i_gain>0.5</i_gain>
      <d_gain>3</d_gain>
      <i_max>5</i_max>
      <i_min>-5</i_min>
      <cmd_max>50</cmd_max>
      <cmd_min>-50</cmd_min>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="libgz-sim-joint-position-controller-system.so"
            name="gz::sim::systems::JointPositionController">
      <joint_name>Chain2_1</joint_name>
      <topic>/delta_3dof/Chain2_1/cmd_pos</topic>
      <p_gain>20</p_gain>
      <i_gain>0.5</i_gain>
      <d_gain>3</d_gain>
      <i_max>5</i_max>
      <i_min>-5</i_min>
      <cmd_max>50</cmd_max>
      <cmd_min>-50</cmd_min>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="libgz-sim-joint-position-controller-system.so"
            name="gz::sim::systems::JointPositionController">
      <joint_name>Chain3_1</joint_name>
      <topic>/delta_3dof/Chain3_1/cmd_pos</topic>
      <p_gain>20</p_gain>
      <i_gain>0.5</i_gain>
      <d_gain>3</d_gain>
      <i_max>5</i_max>
      <i_min>-5</i_min>
      <cmd_max>50</cmd_max>
      <cmd_min>-50</cmd_min>
    </plugin>
  </gazebo>

  <!-- broadcast all joint states back to ROS2 -->
  <gazebo>
    <plugin filename="libgz-sim-joint-state-publisher-system.so"
            name="gz::sim::systems::JointStatePublisher"/>
  </gazebo>

</robot>
