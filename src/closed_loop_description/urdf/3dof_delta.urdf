  </link>
  <joint name="Chain1_top_A" type="revolute">
    <parent link="Chain1_link_1"/>
    <child link="Chain1_top_v1"/>
    <origin xyz="0.075800 0 0" rpy="0 2.140009 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="99999.0" lower="-3.141592653589793" upper="3.141592653589793" velocity="99999.0"/>
    <dynamics damping="0.02" friction="0.0"/>
  </joint>
  <joint name="Chain1_top_B" type="revolute">
