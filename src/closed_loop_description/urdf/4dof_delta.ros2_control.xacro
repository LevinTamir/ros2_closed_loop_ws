<?xml version="1.0"?>
<!-- ros2_control hardware interface for delta_4dof ACTIVE joints (gated by ros2_control:=true):
     the 3 leg motors + the flange-rotation motor Chain4_1. Backed by gz_ros2_control in sim. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="controllers_file"
             default="$(find closed_loop_description)/config/delta_4dof_controllers.yaml"/>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="Chain1_1">
      <command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/>
    </joint>
    <joint name="Chain2_1">
      <command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/>
    </joint>
    <joint name="Chain3_1">
      <command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/>
    </joint>
    <joint name="Chain4_1">
      <command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_file)</parameters>
    </plugin>
  </gazebo>

</robot>
